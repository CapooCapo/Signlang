# --- GLOBAL ---
PROJECT_NAME=signlang
ENVIRONMENT=development

# --- DJANGO API ---
DJANGO_SECRET=dev-secret
DJANGO_DEBUG=1
JWT_SECRET=dev-jwt
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- DATABASE (PostgreSQL) ---
DB_HOST=db
DB_PORT=5433
DB_NAME=signlang
DB_USER=signuser
DB_PASSWORD=signpass

# --- CACHE (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- ML SERVICE ---
ML_HOST=ml
ML_PORT=9000
ML_MODEL_NAME=asl_letters
ML_MODEL_VERSION=1.0.0

# --- FRONTEND ---
WEB_PORT=4200

# --- SYSTEM ---
HOST_UID=1000
HOST_GID=1000

# --- GOOGLE AUTH ---
GOOGLE_CLIENT_ID=454223291940-sp1cr3vangsdk36kse8hdifm999vv2go.apps.googleusercontent.com
ANGULAR_GOOGLE_CLIENT_ID=454223291940-sp1cr3vangsdk36kse8hdifm999vv2go.apps.googleusercontent.com
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-service-account.json
